<?xml version="1.0" encoding="utf-8"?>
<!--
  Generado para publicacion en IIS con el modulo ASP.NET Core (ANCM), hosting
  IN-PROCESS (ver AspNetCoreHostingModel en el .csproj y README "Publicar en IIS").
  `dotnet publish` regenera/actualiza este archivo automaticamente; se versiona una
  copia de referencia porque NO contiene secretos (la cadena de conexion se inyecta
  por variables de entorno del sitio/aplicacion en IIS, no aqui).
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <!--
        Autenticacion Windows/AD integrada (revision de S-6, ver contexto/ESTADO.md):
        requiere el rol/feature "Windows Authentication" instalado en IIS (no viene
        activado por defecto). Si el sitio/pool no permite sobreescribir esta seccion
        ("This configuration section cannot be used..."), desbloquearla una vez en el
        servidor con:
          %windir%\system32\inetsrv\appcmd.exe unlock config /section:windowsAuthentication
          %windir%\system32\inetsrv\appcmd.exe unlock config /section:anonymousAuthentication
      -->
      <security>
        <authentication>
          <anonymousAuthentication enabled="false" />
          <windowsAuthentication enabled="true" />
        </authentication>
      </security>
      <aspNetCore processPath="dotnet"
                  arguments=".\webXMLRespuestaFactElect.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="InProcess"
                  forwardWindowsAuthToken="true">
        <!--
          Variables de entorno del sitio en IIS (Administrador de IIS > Application
          Pools / Configuration Editor, o appcmd) - NO se escriben valores reales aqui:
          ConnectionStrings__CadenaConexionDB = <cadena real, gestionada por el Lead>
        -->
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
